{
  "package_name": "My Package",
  "package_description": "One or two sentence description of the package...",
  "is_subproject": true,
  "include_gpu": false,
  "package_url": "https://github.com/user/my-package",
  "author_name": "Your Name",
  "author_email": "your.name@example.com",
  "python_version": "3.13",
  "uv_version": "0.6.12",
  "timezone": "Europe/Vienna",
  "docstring_style": ["google", "numpy"],
  "open_source_license": ["MIT", "Apache-2.0", "BSD-3-Clause", "Proprietary"],
  "ci_platform": ["github", "gitlab", "both"],
  "gitlab_registry": "registry.gitlab.com",
  "include_docker": true,
  "include_devcontainer": true,
  "include_mkdocs": true,
  "include_precommit": true,
  "type_checker": ["mypy", "ty", "none"],
  "include_cli": false,
  "include_security_scans": true,
  "include_pypi_publish": true,
  "__package_name_kebab_case": "{{ cookiecutter.package_name|slugify }}",
  "__package_name_snake_case": "{{ cookiecutter.package_name|slugify(separator='_') }}",
  "__year": "{% now 'utc', '%Y' %}"
}
