// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-dockerfile
{
    "name": "DEV Container",
    "dockerComposeFile": "./docker-compose.yml",
    "service": "devcontainer",
    "workspaceFolder": "/workspace",
    "features": {
		// https://containers.dev/features
        // "ghcr.io/devcontainers/features/git-lfs:1": {
        //     "autoPull": true,
        //     "version": "latest"
        // }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "alefragnani.project-manager",
                "dotjoshjohnson.xml",
                "github.copilot",
                "github.copilot-chat",
                "github.github-vscode-theme",
                "gruntfuggly.todo-tree",
                "james-yu.latex-workshop",
                "janisdd.vscode-edit-csv",
                "johnpapa.vscode-peacock",
                "mechatroner.rainbow-csv",
                "mhutchie.git-graph",
                "ms-azuretools.vscode-docker",
                "ms-python.black-formatter",
                "ms-python.debugpy",
                "ms-python.isort",
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-toolsai.datawrangler",
                "ms-toolsai.jupyter",
                "ms-toolsai.jupyter-keymap",
                "ms-toolsai.jupyter-renderers",
                "ms-toolsai.tensorboard",
                "ms-toolsai.vscode-jupyter-cell-tags",
                "ms-toolsai.vscode-jupyter-slideshow",
                "ms-vscode-remote.remote-containers",
                "ms-vscode-remote.remote-ssh",
                "ms-vscode-remote.remote-ssh-edit",
                "ms-vscode-remote.remote-wsl",
                "ms-vscode.remote-explorer",
                "tamasfe.even-better-toml",
                "yzane.markdown-pdf",
                "yzhang.markdown-all-in-one",
                "Anthropic.claude-code",
                "github.vscode-github-actions"
            ],
            "settings": {
				"terminal.integrated.shell.linux": "/bin/bash",
                "python.venvFolders": [
                    "~/.cache/pypoetry/virtualenvs"
                ]
			}
        }
    },

    // Use 'forwardPorts' to make a list of ports inside the container available locally.
    // "forwardPorts": [],

    // Uncomment the next line to run commands after the container is created.
    "postCreateCommand": "echo \"alias poeprecommit='poe precommit'\" >> ~/.bashrc && echo \"alias poecheck='poe check'\" >> ~/.bashrc && echo \"alias poetest='poe test'\" >> ~/.bashrc && echo \"alias poerun='poe precommit; poe check; poe test;'\" >> ~/.bashrc && echo \"alias poeprecommit='poe precommit'\" >> ~/.zshrc && echo \"alias poecheck='poe check'\" >> ~/.zshrc && echo \"alias poetest='poe test'\" >> ~/.zshrc && echo \"alias poerun='poe precommit; poe check; poe test;'\" >> ~/.zshrc"

    // Uncomment to connect as an existing user other than the container default. More info: https://aka.ms/dev-containers-non-root.
    // "remoteUser": "devcontainer"
}
