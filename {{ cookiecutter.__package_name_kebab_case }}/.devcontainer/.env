# Put shared environment variables here - these will be committed

# Automatically map SHORTUSER to the host OS's native username variable
SHORTUSER=${USER:-${USERNAME:-anonymous}}

# Standard for our configuration
COMPOSE_PROJECT_NAME={{ cookiecutter.__package_name_kebab_case }}-${SHORTUSER}
DEVCONTAINER_NAME=${COMPOSE_PROJECT_NAME}-devcontainer

# Must match VENV_PATH in Dockerfile / docker-compose.yml
# Prevents "VIRTUAL_ENV does not match project environment" warnings from uv
VIRTUAL_ENV=/opt/venv
